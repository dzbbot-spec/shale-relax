# ═══════════════════════════════════════════════════════
# Шале Релакс — шаблон конфигурации
# Скопируйте этот файл в .env и заполните все поля
# НИКОГДА не коммитьте .env в git!
# ═══════════════════════════════════════════════════════

# ─── Telegram ──────────────────────────────────────────
# Токен бота от @BotFather
TELEGRAM_BOT_TOKEN=

# Chat ID владельца (куда пересылать заявки).
# Узнать свой chat_id: написать /start боту @userinfobot
OWNER_CHAT_ID=

# Username владельца (для информации, не для авторизации)
OWNER_USERNAME=@shale_relax_elbrus

# Chat ID управляющего (авторизован отправлять фото в конвейер)
MANAGER_CHAT_ID=

# Username управляющего (альтернатива chat_id, без символа @)
MANAGER_USERNAME=

# ─── OpenAI ────────────────────────────────────────────
# API-ключ OpenAI для генерации подписей через GPT
OPENAI_API_KEY=

# Модель GPT (рекомендуется gpt-4o-mini для баланса цена/качество)
OPENAI_MODEL=gpt-4o-mini

# ─── Kling AI / Umnik.ai ───────────────────────────────
# API-ключ Kling (получить в личном кабинете umnik.ai)
UMNIK_KLING_API_KEY=

# Модель Kling для генерации видео
KLING_MODEL=kling-v1

# ─── Smmbox ────────────────────────────────────────────
# API-ключ Smmbox (получить в настройках аккаунта smmbox.com)
SMMBOX_API_KEY=

# ID аккаунта Instagram в Smmbox (найти в настройках подключённых аккаунтов)
SMMBOX_ACCOUNT_ID=

# ─── Instagram (информационно) ─────────────────────────
INSTAGRAM_USERNAME=shale_relax_elbrus
INSTAGRAM_LOGIN=dzablaev@gmail.com

# ─── Пути ──────────────────────────────────────────────
DOWNLOAD_PATH=./downloads
LOGS_PATH=./logs

# ─── Повторные попытки при ошибках ────────────────────
MAX_RETRIES=3
RETRY_DELAY_SECONDS=5

# ─── Логирование ───────────────────────────────────────
# Уровень: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ─── Расписание ────────────────────────────────────────
TIMEZONE=Europe/Moscow

# ─── Режим отладки ─────────────────────────────────────
DEBUG=False
